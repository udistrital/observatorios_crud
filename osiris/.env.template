DEBUG=true
SECRET_KEY=dev-insecure-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=
DJANGO_LOG_LEVEL=INFO

# Se puede apuntar a elasticsearch local o remoto. Para usar el remoto se puede usar tunneling del puerto donde se ejecuta elasticsearch con el siguiente comando
# ssh -i llave.pem -L 0.0.0.0:9200:localhost:9200 {user}@{host_remoto}

ELASTICSEARCH_HOST=host.docker.internal
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_MAIN_INDEX=

# En local, las credenciales salen de .env (ELASTICSEARCH_USERNAME / ELASTICSEARCH_PASSWORD).
# Si se define PARAMETER_STORE, las credenciales se obtienen desde AWS SSM.
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

PARAMETER_STORE=
AWS_REGION=
